# Public Trading Race API (no token)
VITE_RACE_API_URL=https://ai-api.open4dev.xyz

# Dev-only: Vite proxy target for `/api` (recommended to avoid CORS in the browser)
VITE_DEV_PROXY_TARGET=https://ai-api.open4dev.xyz

# Optional override; otherwise uses `${window.location.origin}/tonconnect-manifest.json`
# VITE_TONCONNECT_MANIFEST_URL=https://your-domain.com/tonconnect-manifest.json

# Generate `public/tonconnect-manifest.json` (runs automatically in `npm run dev`/`npm run build`)
# For production builds you MUST set this to your deployed https origin.
# TONCONNECT_APP_URL=https://your-domain.com
