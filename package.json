{
  "name": "ai-trader-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "gen:tonconnect-manifest": "node scripts/write-tonconnect-manifest.mjs",
    "dev": "npm run gen:tonconnect-manifest && vite",
    "build": "npm run gen:tonconnect-manifest && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npx wrangler pages deploy dist --project-name ai-trader",
    "deploy:preview": "npx wrangler pages deploy dist --project-name ai-trader --branch preview"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.2.2",
    "@tonconnect/ui-react": "^2.4.1",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.18",
    "framer-motion": "^12.38.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.574.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0"
  }
}
